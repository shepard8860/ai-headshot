# ============================================================
# AI职业形象照 - 环境变量模板
# 复制本文件为 .dev.vars（本地开发）或在 Cloudflare Dashboard 设置生产变量
# ============================================================

# --------------------------------------------------
# 1. LeanCloud 数据库配置
# 获取方式: https://leancloud.cn → 创建应用 → 设置 → 应用凭证
# --------------------------------------------------
LEANCLOUD_APP_ID=your_leancloud_app_id
LEANCLOUD_APP_KEY=your_leancloud_app_key
LEANCLOUD_SERVER_URL=https://your-leancloud-server.example.com

# --------------------------------------------------
# 2. 商汤 SenseNova AI 配置
# 获取方式: https://platform.sensenova.cn → 创建 API Key
# --------------------------------------------------
SENSENOVA_API_KEY=your_sensenova_api_key
SENSENOVA_API_URL=https://api.sensenova.cn/v1

# --------------------------------------------------
# 3. 阿里云配置（OSS + 通义万相）
# 获取方式: https://ram.console.aliyun.com → 创建 AccessKey
# --------------------------------------------------
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=ai-headshot-bucket
ALIYUN_WANXI_API_URL=https://dashscope.aliyuncs.com/api/v1

# --------------------------------------------------
# 4. Apple App Store IAP 配置
# 获取方式: App Store Connect → 应用 → 功能 →  App 内购买项目 → 共享密钥
# --------------------------------------------------
APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_SANDBOX_URL=https://sandbox.itunes.apple.com/verifyReceipt
APPLE_PRODUCTION_URL=https://buy.itunes.apple.com/verifyReceipt

# --------------------------------------------------
# 5. 管理后台 Basic Auth（可选，生产环境建议设置）
# --------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_now

# --------------------------------------------------
# 6. Cloudflare KV Namespace ID（通过 wrangler.toml 或 Dashboard 配置）
# 获取方式: Cloudflare Dashboard → Workers & Pages → KV
# --------------------------------------------------
# HEADSHOT_KV=your_kv_namespace_id

# --------------------------------------------------
# 7. 微信小程序配置（如需要）
# 获取方式: 微信公众平台 → 开发 → 开发管理 → 开发设置
# --------------------------------------------------
WECHAT_APP_ID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
